# ─────────────────────────────────────────────────────────────────────────────
# MR Checker — пример файла переменных окружения
# Скопируйте в .env и заполните обязательные параметры.
# Файл .env не должен попасть в Git (добавьте .env в .gitignore)!
# ─────────────────────────────────────────────────────────────────────────────

# ─── ОБЯЗАТЕЛЬНЫЕ — без этих сервис не запустится ─────────────────────

# GitLab Personal Access Token (права: api, read_repository)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# API-ключ OpenAI-совместимого провайдера
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# GitLab PAT для class-context — обычно равен GITLAB_TOKEN
CLASS_CONTEXT_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ─── ОПЦИОНАЛЬНЫЕ — оверрайд дефолтов из docker-compose.yml ─────

# Порт приложения (HTTP API + Swagger)
#APP_PORT=8081

# Порт H2 TCP-сервера (для DBeaver / IntelliJ Database)
#H2_TCP_PORT=9092

# Пользователь и пароль H2 (sa / пусто — дефолт)
#H2_USER=sa
#H2_PASSWORD=

# Локальный LLM API (если отличается от дефолта)
#OPENAI_BASE_URL=https://chat.ehd-zr.cbr.ru
#OPENAI_MODEL=Qwen/Qwen3.5-397B-A17B-GPTQ-Int4
#OPENAI_COMPLETIONS_PATH=/openai/chat/completions

# GitLab (если отличается от дефолта)
#GITLAB_URL=http://10.1.5.6/

# java-class-context (если отличается от дефолта)
#CLASS_CONTEXT_URL=http://10.1.5.97:8084

# webhook-distributor (если отличается от дефолта)
#WEBHOOK_DISTRIBUTOR_URL=http://10.1.5.97:8081

# Docker-образ mr-checker (если используется готовый образ из registry)
#DOCKER_IMAGE=registry.example.com/mr-checker:1.2.3

# Spring-профиль (дефолт: default; local включает H2 console)
#SPRING_PROFILES_ACTIVE=default

# ─── MCP GitLab (jmrplens/gitlab-mcp-server) ─────────────────────────
# Порт supergateway (Streamable HTTP → stdio транслятор)
# Open WebUI подключается к http://<host>:${MCP_PORT}/mcp
#MCP_PORT=8811

# TOOL_SURFACE: dynamic (2 tools, default) | meta (30 групп) | individual (866 tools)
# meta рекомендуется для Open WebUI — баланс покрытия и размера контекста
#TOOL_SURFACE=meta
